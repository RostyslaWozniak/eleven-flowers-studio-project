{
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|gif|webp|svg|ico)$",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],

  "crons": [
    {
      "path": "/api/cron/order-notification",
      "schedule": "0 7 * * *"
    }
  ]
}
